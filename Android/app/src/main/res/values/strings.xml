    <string name="help_text_lan">LAN mode: automatically finds devices on the same Wi-Fi and sends files directly.</string>
    <string name="help_text_tunnel">Tunnel mode: lets you exchange files directly over P2P even across external networks. Start the connection first with Apply and Reconnect in Tunnel Settings.</string>
    <string name="help_text_refresh">Refresh: LAN rescans immediately, while Tunnel reloads peers only after the tunnel connection has started.</string>
    <string name="help_text_save_folder">Save Folder: files are saved to the phone Download folder by default. You can change it with the Save Folder button.</string>
    <string name="help_text_send_files">Send Files: select a device first, then tap Send Files. You can send multiple files at once.</string>
    <string name="help_text_background">Background Receive: once transfer starts, it keeps receiving even if the screen turns off.</string>
    <string name="help_text_gallery">Gallery: manage and delete received images and videos at a glance. Saved images can also be viewed in the default phone gallery app.</string>
